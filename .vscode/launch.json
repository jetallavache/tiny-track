{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug-tinytd",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tinytd/tinytd",
            "args": ["-c", "etc/tinytrack.conf-debug"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            // "environment": [
            //     {
            //         "name": "TINYTRACK_LIVE_PATH",
            //         "value": "/dev/shm/tinytd-live.dat"
            //     },
            //     {
            //         "name": "TINYTRACK_SHADOW_PATH",
            //         "value": "/dev/shm/tinytd-shadow.dat"
            //     }
            // ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "debug-tiny-cli",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cli/tiny-cli",
            "args": ["live"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "TINYTRACK_LIVE_PATH",
                    "value": "/dev/shm/tinytd-live.dat"
                },
                {
                    "name": "TINYTRACK_SHADOW_PATH",
                    "value": "/dev/shm/tinytd-shadow.dat"
                }
            ],
            "preLaunchTask": "start-tinytd-daemon",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
